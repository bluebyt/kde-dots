sort=-time
layer=bottom
background-color=#2E3440CC
text-color=#c0caf5
width=300
height=110
border-size=2
border-color=#5e81ac
border-radius=15
icons=1
max-icon-size=64
max-history=30
default-timeout=900000
ignore-timeout=1
font=CaskaydiaCove Nerd Font 12

[urgency=low]
border-color=#7aa2f7

[urgency=normal]
border-color=#7aa2f7

[urgency=high]
border-color=#bf616a
default-timeout=0

[category=mpd]
default-timeout=20000
group-by=category

[app-name="Element"]
on-notify=exec ~/.config/scripts/matrix.sh

[app-name="Firefox"]
on-button-left=exec ~/.config/scripts/firefox-mako.sh
# on-button-left=invoke-default-action

[desktop-entry="im.riot.Riot"]
on-button-left=exec ~/.config/scripts/matrix.sh

